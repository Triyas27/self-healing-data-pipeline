# Database. SQLite by default, switch to Postgres via DATABASE_URL only.
DATABASE_URL=sqlite:///./data/pipeline.db

# LLM diagnosis, falls back to heuristic mode if unset or unreachable.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Repair behavior
MAX_REPAIR_ATTEMPTS=3

# Alerting
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# API
API_HOST=0.0.0.0
API_PORT=8000
