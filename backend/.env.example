# Database. SQLite by default (async driver), switch to Postgres via
# DATABASE_URL only, e.g. postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./data/pipeline.db

# LLM diagnosis, falls back to heuristic mode if unset or unreachable.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Repair behavior
MAX_REPAIR_ATTEMPTS=3
MAX_CONCURRENT_DIAGNOSES=8

# Ingestion limits
MAX_UPLOAD_ROWS=10000

# Alerting
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# API
API_HOST=0.0.0.0
API_PORT=8000
